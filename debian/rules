#!/usr/bin/make -f

# Uncomment this to turn on verbose mode.
#export DH_VERBOSE=1

export DEB_BUILD_MAINT_OPTIONS = hardening=+all

%:
	dh $@ --with python3

override_dh_auto_configure:
	dh_auto_configure -- -DENABLE_DOTNET_LIB=1 \
		-DDISABLE_BUILDINFO=1 \
		-DCMAKE_BUILD_RPATH_USE_ORIGIN=ON \
		-DHAVE_LINUX_API=1 \
		-DHAVE_EXYNOS_API=1 \
		-DHAVE_AOCEC_API=1
